        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@cucumber/cucumber": "^9.5.1",
        "@types/chai": "^5.2.3",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.6",
        "chai": "^4.3.10",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    }
}
