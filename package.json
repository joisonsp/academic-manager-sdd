{
    "name": "gestao-academica",
    "version": "1.0.0",
    "description": "Sistema de Gestão Acadêmica - Gerenciamento de Alunos",
    "main": "src/backend/server.ts",
    "type": "module",
    "scripts": {
        "test": "cucumber-js tests/features/**/*.feature --import tsx --import tests/steps/**/*.ts",
        "test:creation": "cucumber-js tests/features/alunos-criacao.feature --import tsx --import tests/steps/**/*.ts",
        "test:watch": "cucumber-js --watch",
        "dev": "tsx src/backend/server.ts",
        "build": "tsc",
        "start": "node dist/backend/server.js"
