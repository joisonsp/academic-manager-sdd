{
    "name": "gestao-academica",
    "version": "1.0.0",
    "description": "Sistema de Gestão Acadêmica - Gerenciamento de Alunos",
    "main": "src/backend/server.ts",
    "type": "module",
    "scripts": {
        "test": "cucumber-js tests/features/**/*.feature --import tsx --import tests/steps/**/*.ts",
        "test:creation": "cucumber-js tests/features/alunos-criacao.feature --import tsx --import tests/steps/**/*.ts",
        "test:consultation": "cucumber-js tests/features/alunos-consulta.feature --import tsx --import tests/steps/**/*.ts",
        "test:update-delete": "cucumber-js tests/features/alunos-update-delete.feature --import tsx --import tests/steps/**/*.ts",
        "test:turmas": "cucumber-js tests/features/turmas-avaliacoes.feature --import tsx --import tests/steps/**/*.ts",
        "test:watch": "cucumber-js --watch",
        "dev": "tsx src/backend/server.ts",
        "dev:frontend": "vite --host",
        "build": "tsc",
        "build:frontend": "vite build src/frontend",
        "start": "node dist/backend/server.js"
    },
    "keywords": [
        "gestao",
        "academica",
        "alunos",
        "crud",
        "tdd"
    ],
    "author": "Mestrado IA+Código",
    "license": "MIT",
    "dependencies": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "axios": "^1.15.2",
        "cors": "^2.8.6",
        "express": "^4.18.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "uuid": "^9.0.0",
        "vite": "^8.0.9"
    },
    "devDependencies": {
        "@cucumber/cucumber": "^9.5.1",
        "@types/chai": "^5.2.3",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.6",
        "chai": "^4.3.10",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    }
}
